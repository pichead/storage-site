# ============================================================
# Environment Variables - Storage Site
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าให้ครบ
# ============================================================

# ─── Raspberry Pi / Host Settings ───────────────────────────
# IP ของ Raspberry Pi (ใช้แทน localhost เมื่อเข้าถึงจากอุปกรณ์อื่น)
# RASPBERRY_PI_IP=192.168.1.xxx

# ─── Backend (NestJS) ───────────────────────────────────────
BACKEND_PORT=3333

# ─── Frontend (Next.js) ─────────────────────────────────────
FRONTEND_PORT=3000
# ชี้ไปที่ Raspberry Pi IP จากมุมมองของ browser (client-side)
NEXT_PUBLIC_API_URL=http://192.168.1.xxx:3333/api/v1

# ─── MySQL Database ─────────────────────────────────────────
MYSQL_DATABASE=storage
MYSQL_ROOT_PASSWORD=change_this_root_password_please
MYSQL_DATABASE_USER=storage_user
MYSQL_DATABASE_PASSWORD=change_this_db_password_please
MYSQL_EXPOSED_PORT=33066

# ─── JWT Secrets (เปลี่ยนเป็น random string ที่ซับซ้อน) ────
JWT_ACCESS_SECRET_KEY=your_super_secret_access_key_change_this
JWT_REFRESH_SECRET_KEY=your_super_secret_refresh_key_change_this
JWT_ACCESS_EXPIRATION_TIME=900
JWT_REFRESH_EXPIRATION_TIME=2592000

# ─── phpMyAdmin (optional) ──────────────────────────────────
PHPMYADMIN_PORT=8081
